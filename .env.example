# Ejemplo de archivo de variables de entorno
# Copiar este archivo como .env y configurar los valores

# Django Settings
SECRET_KEY=tu_clave_secreta_aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos local (PostgreSQL)
# Se usa cuando DATABASE_URL no está definido
DATABASE_NAME=manicuredb
DATABASE_USER=postgres
DATABASE_PASSWORD=tu_password
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Base de datos de tests (opcional)
TEST_DATABASE_NAME=test_manicuredb

# Base de datos en producción (Render)
# Si está definido, ignora las variables DATABASE_* de arriba
# DATABASE_URL=postgresql://user:password@host:5432/dbname
